# ─────────────────────────────────────────────
#  Copy this file to .env and fill in the keys
# ─────────────────────────────────────────────

# Anthropic Claude — used by ALL three Claude agents
# (conversation parsing, level difficulty, SVG sprite generation)
# Get a key at: https://console.anthropic.com/  (free $5 credit on signup)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Hugging Face — used by the Background Agent to generate the AI background image
# Get a free token at: https://huggingface.co/settings/tokens  (Read scope)
HF_TOKEN=your_hf_token_here

# ─────────────────────────────────────────────
#  NOTE: The app degrades gracefully without keys:
#   - No ANTHROPIC_API_KEY → heuristic params + built-in SVG library
#   - No HF_TOKEN          → game uses procedural sky gradient instead
# ─────────────────────────────────────────────
